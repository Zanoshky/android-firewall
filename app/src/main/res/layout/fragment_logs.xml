<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Connection Logs"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/btnClearLogs"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="Clear"
            android:textColor="@color/accent_pink"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_toggle_off"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Filter -->
    <EditText
        android:id="@+id/editFilterLogs"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_search"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="10dp"
        android:drawableTint="@color/text_hint"
        android:hint="Filter by app, IP, or domain..."
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:inputType="text"
        android:paddingHorizontal="16dp"
        android:importantForAutofill="no" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerLogs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/txtEmptyLogs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No connection logs yet.\nLogs appear when apps try to connect."
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>
