<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true">

    <!-- Ambient glow orbs (decorative) -->
    <View
        android:id="@+id/orbPurple"
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:layout_marginStart="-100dp"
        android:layout_marginTop="-80dp"
        android:background="@drawable/orb_purple" />

    <View
        android:id="@+id/orbCyan"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="-80dp"
        android:layout_marginBottom="100dp"
        android:background="@drawable/orb_cyan" />

    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="300dp"
        android:background="@drawable/orb_pink" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="48dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Firewall"
                        android:textColor="@color/text_primary"
                        android:textSize="32sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="-0.02" />

                    <TextView
                        android:id="@+id/txtSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All traffic blocked"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Power button card -->
                <FrameLayout
                    android:id="@+id/powerButton"
                    android:layout_width="64dp"
                    android:layout_height="36dp"
                    android:contentDescription="Toggle firewall">

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchFirewall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        app:thumbTint="@color/accent_cyan"
                        app:trackTint="@color/toggle_off" />
                </FrameLayout>
            </LinearLayout>

            <!-- Status badge -->
            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_status_badge"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="● Protected"
                android:textColor="@color/status_active"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium" />

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/txtBlockedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/accent_pink"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Blocked"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:id="@+id/txtAllowedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/accent_cyan"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Allowed"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Tab filter -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="24dp"
            android:background="@drawable/bg_glass_card"
            app:tabIndicator="@drawable/bg_tab_indicator"
            app:tabIndicatorColor="@color/accent_cyan"
            app:tabTextColor="@color/text_secondary"
            app:tabSelectedTextColor="@color/text_primary"
            app:tabRippleColor="@color/toggle_off"
            app:tabMode="fixed"
            app:tabGravity="fill">

            <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="All" />
            <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="User" />
            <com.google.android.material.tabs.TabItem android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="System" />
        </com.google.android.material.tabs.TabLayout>

        <!-- Search bar -->
        <EditText
            android:id="@+id/editSearch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_search"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="12dp"
            android:drawableTint="@color/text_hint"
            android:hint="Search apps or packages..."
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:inputType="text"
            android:paddingHorizontal="16dp"
            android:importantForAutofill="no" />

        <!-- App list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerApps"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false"
            android:layoutAnimation="@anim/layout_animation_fall_down" />

        <!-- Credit -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="Made by Marko Zanoški, free with love."
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:fontFamily="sans-serif-light" />

    </LinearLayout>
</FrameLayout>
