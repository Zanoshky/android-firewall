<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp"
    android:background="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/imgIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="App icon" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/txtSystemBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYS"
                android:textSize="9sp"
                android:textColor="@color/accent_blue"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_badge"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:layout_marginStart="6dp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtPackage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:ellipsize="middle"
            android:singleLine="true"
            android:maxWidth="200dp"
            android:layout_marginTop="1dp" />

        <TextView
            android:id="@+id/txtAppStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp"
            android:visibility="gone" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/btnWifi"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_toggle_off"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Toggle Wi-Fi access">

        <TextView
            android:id="@+id/txtWifi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="W"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif-medium" />
    </FrameLayout>

    <View
        android:layout_width="6dp"
        android:layout_height="0dp" />

    <FrameLayout
        android:id="@+id/btnMobile"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_toggle_off"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Toggle mobile data access">

        <TextView
            android:id="@+id/txtMobile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="M"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif-medium" />
    </FrameLayout>
</LinearLayout>
