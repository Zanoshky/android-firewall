<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="5dp">

    <!-- App icon -->
    <ImageView
        android:id="@+id/imgIcon"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:contentDescription="App icon" />

    <!-- App info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/txtName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/txtPackage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:ellipsize="middle"
            android:singleLine="true"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/txtSystemBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM"
            android:textSize="9sp"
            android:textColor="@color/accent_pink"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_toggle_off"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:layout_marginTop="4dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Wi-Fi toggle -->
    <FrameLayout
        android:id="@+id/btnWifi"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_toggle_off"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Toggle Wi-Fi access">

        <TextView
            android:id="@+id/txtWifi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="W"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif-medium" />
    </FrameLayout>

    <View
        android:layout_width="10dp"
        android:layout_height="0dp" />

    <!-- Mobile data toggle -->
    <FrameLayout
        android:id="@+id/btnMobile"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_toggle_off"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Toggle mobile data access">

        <TextView
            android:id="@+id/txtMobile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="M"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif-medium" />
    </FrameLayout>
</LinearLayout>
